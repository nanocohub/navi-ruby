<div class="mb-6 flex justify-between items-center">
  <div>
    <h1 class="text-2xl font-bold text-gray-900" style="margin-bottom: 2px;">Dashboard</h1>
    <p class="text-gray-500 text-sm m-0">Real-time performance monitoring</p>
  </div>
</div>

<div class="border-b mb-6">
  <nav class="flex gap-6">
    <a href="?tab=overview&period=<%= @period %>" class="pb-3 font-medium <%= @tab == 'overview' ? 'border-b-2 border-blue-600 text-blue-600' : 'text-gray-500 hover:text-gray-700' %>">Overview</a>
    <a href="?tab=queries&period=<%= @period %>" class="pb-3 font-medium <%= @tab == 'queries' ? 'border-b-2 border-blue-600 text-blue-600' : 'text-gray-500 hover:text-gray-700' %>">Queries</a>
    <a href="?tab=external&period=<%= @period %>" class="pb-3 font-medium <%= @tab == 'external' ? 'border-b-2 border-blue-600 text-blue-600' : 'text-gray-500 hover:text-gray-700' %>">External Requests</a>
    <a href="?tab=caches&period=<%= @period %>" class="pb-3 font-medium <%= @tab == 'caches' ? 'border-b-2 border-blue-600 text-blue-600' : 'text-gray-500 hover:text-gray-700' %>">Caches</a>
    <a href="?tab=queues&period=<%= @period %>" class="pb-3 font-medium <%= @tab == 'queues' ? 'border-b-2 border-blue-600 text-blue-600' : 'text-gray-500 hover:text-gray-700' %>">Queues</a>
  </nav>
</div>

<% if @tab == 'overview' %>
  <% permitted_params = params.permit(:period, :stats_period, :requests_period, :latency_period, :issues_period, :queries_period) %>
  <div class="mb-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide m-0">Overview Stats</h2>
      <form method="get" class="m-0" data-turbo="true">
        <input type="hidden" name="tab" value="<%= @tab %>">
        <% permitted_params.except(:stats_period).each do |k, v| %>
          <input type="hidden" name="<%= k %>" value="<%= v %>">
        <% end %>
        <select name="stats_period" class="border rounded px-2 py-1 text-xs bg-white cursor-pointer shadow-sm m-0" onchange="this.form.submit()">
          <option value="15m" <%= 'selected' if @period_stats == '15m' %>>Last 15m</option>
          <option value="1h" <%= 'selected' if @period_stats == '1h' %>>Last 1h</option>
          <option value="6h" <%= 'selected' if @period_stats == '6h' %>>Last 6h</option>
          <option value="24h" <%= 'selected' if @period_stats == '24h' %>>Last 24h</option>
          <option value="7d" <%= 'selected' if @period_stats == '7d' %>>Last 7d</option>
        </select>
      </form>
    </div>

    <div class="stat-grid mb-6">
      <div class="stat-card">
        <div class="stat-value"><%= number_with_delimiter(@throughput) %></div>
        <div class="stat-label">Requests (period)</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= format_duration(@percentiles['p50']) %></div>
        <div class="stat-label">P50 Latency</div>
      </div>
      <div class="stat-card">
        <div class="stat-value text-yellow-600"><%= format_duration(@percentiles['p90']) %></div>
        <div class="stat-label">P90 Latency</div>
      </div>
      <div class="stat-card">
        <div class="stat-value text-red-600"><%= format_duration(@percentiles['p99']) %></div>
        <div class="stat-label">P99 Latency</div>
      </div>
      <div class="stat-card">
        <div class="stat-value <%= @error_rate > 5 ? 'text-red-600' : 'text-green-600' %>"><%= @error_rate %>%</div>
        <div class="stat-label">Error Rate</div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <div class="stat-card">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide m-0">Requests & Errors</h2>
        <form method="get" class="m-0" data-turbo="true">
          <input type="hidden" name="tab" value="<%= @tab %>">
          <% permitted_params.except(:requests_period).each do |k, v| %>
            <input type="hidden" name="<%= k %>" value="<%= v %>">
          <% end %>
          <select name="requests_period" class="border rounded px-2 py-1 text-xs bg-white cursor-pointer shadow-sm m-0" onchange="this.form.submit()">
            <option value="15m" <%= 'selected' if @period_requests == '15m' %>>Last 15m</option>
            <option value="1h" <%= 'selected' if @period_requests == '1h' %>>Last 1h</option>
            <option value="6h" <%= 'selected' if @period_requests == '6h' %>>Last 6h</option>
            <option value="24h" <%= 'selected' if @period_requests == '24h' %>>Last 24h</option>
            <option value="7d" <%= 'selected' if @period_requests == '7d' %>>Last 7d</option>
          </select>
        </form>
      </div>
      <div id="requests-chart" style="height: 250px;"></div>
    </div>
    <div class="stat-card">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide m-0">API Latency</h2>
        <form method="get" class="m-0" data-turbo="true">
          <input type="hidden" name="tab" value="<%= @tab %>">
          <% permitted_params.except(:latency_period).each do |k, v| %>
            <input type="hidden" name="<%= k %>" value="<%= v %>">
          <% end %>
          <select name="latency_period" class="border rounded px-2 py-1 text-xs bg-white cursor-pointer shadow-sm m-0" onchange="this.form.submit()">
            <option value="15m" <%= 'selected' if @period_latency == '15m' %>>Last 15m</option>
            <option value="1h" <%= 'selected' if @period_latency == '1h' %>>Last 1h</option>
            <option value="6h" <%= 'selected' if @period_latency == '6h' %>>Last 6h</option>
            <option value="24h" <%= 'selected' if @period_latency == '24h' %>>Last 24h</option>
            <option value="7d" <%= 'selected' if @period_latency == '7d' %>>Last 7d</option>
          </select>
        </form>
      </div>
      <div id="latency-chart" style="height: 250px;"></div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <div class="stat-card">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide m-0">Issues (<%= @issues.size %>)</h2>
        <form method="get" class="m-0" data-turbo="true">
          <input type="hidden" name="tab" value="<%= @tab %>">
          <% permitted_params.except(:issues_period).each do |k, v| %>
            <input type="hidden" name="<%= k %>" value="<%= v %>">
          <% end %>
          <select name="issues_period" class="border rounded px-2 py-1 text-xs bg-white cursor-pointer shadow-sm m-0" onchange="this.form.submit()">
            <option value="15m" <%= 'selected' if @period_issues == '15m' %>>Last 15m</option>
            <option value="1h" <%= 'selected' if @period_issues == '1h' %>>Last 1h</option>
            <option value="6h" <%= 'selected' if @period_issues == '6h' %>>Last 6h</option>
            <option value="24h" <%= 'selected' if @period_issues == '24h' %>>Last 24h</option>
            <option value="7d" <%= 'selected' if @period_issues == '7d' %>>Last 7d</option>
          </select>
        </form>
      </div>
      <% if @issues.any? %>
        <div class="table-container" style="max-height: 400px;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Type</th>
                <th>Issue</th>
                <th>Count</th>
              </tr>
            </thead>
            <tbody>
              <% @issues.each do |issue| %>
                <tr>
                  <td>
                    <span class="badge <%= issue[:type] == 'Error' ? 'badge-red' : 'badge-yellow' %>">
                      <%= issue[:type] %>
                    </span>
                  </td>
                  <td>
                    <div class="font-medium text-gray-900 truncate" style="max-width: 250px;" title="<%= issue[:title] %>">
                      <%= issue[:title] %>
                    </div>
                    <div class="text-xs text-gray-500 truncate" style="max-width: 250px;" title="<%= issue[:location] %>">
                      <%= issue[:location] %>
                    </div>
                  </td>
                  <td class="font-semibold"><%= number_with_delimiter(issue[:count]) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-gray-500 text-sm">No issues detected in this time range.</p>
      <% end %>
    </div>

    <div class="stat-card">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide m-0">Top Slow Queries</h2>
        <form method="get" class="m-0" data-turbo="true">
          <input type="hidden" name="tab" value="<%= @tab %>">
          <% permitted_params.except(:queries_period).each do |k, v| %>
            <input type="hidden" name="<%= k %>" value="<%= v %>">
          <% end %>
          <select name="queries_period" class="border rounded px-2 py-1 text-xs bg-white cursor-pointer shadow-sm m-0" onchange="this.form.submit()">
            <option value="15m" <%= 'selected' if @period_queries == '15m' %>>Last 15m</option>
            <option value="1h" <%= 'selected' if @period_queries == '1h' %>>Last 1h</option>
            <option value="6h" <%= 'selected' if @period_queries == '6h' %>>Last 6h</option>
            <option value="24h" <%= 'selected' if @period_queries == '24h' %>>Last 24h</option>
            <option value="7d" <%= 'selected' if @period_queries == '7d' %>>Last 7d</option>
          </select>
        </form>
      </div>
      <% if @top_slow_queries.any? %>
        <div class="table-container" style="max-height: 400px;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Query</th>
                <th>Calls</th>
                <th>Avg Time</th>
              </tr>
            </thead>
            <tbody>
              <% @top_slow_queries.each do |query| %>
                <tr>
                  <td>
                    <%= link_to nanoco_apm.slow_queries_path, class: 'hover:underline', title: query['sql_preview'] do %>
                      <div class="text-xs font-mono text-gray-700 truncate" style="max-width: 250px;">
                        <%= query['sql_preview'] %>
                      </div>
                    <% end %>
                  </td>
                  <td><%= number_with_delimiter(query['call_count']) %></td>
                  <td class="font-semibold text-red-600"><%= format_duration(query['avg_duration_ms']) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-gray-500 text-sm">No slow queries detected in this time range.</p>
      <% end %>
    </div>
  </div>

  <script>
  (function() {
    function renderCharts() {
      var reqEl = document.querySelector('#requests-chart');
      var latEl = document.querySelector('#latency-chart');
      if (!reqEl || !latEl) return;
      
      reqEl.innerHTML = '';
      latEl.innerHTML = '';

      var requestsTsData = <%= raw @time_series_requests.to_json %>;
      var latencyTsData = <%= raw @time_series_latency.to_json %>;
      
      var requestsData = requestsTsData.map(function(r) { return { x: r['bucket'], y: (r['total_requests'] || 0) - (r['error_requests'] || 0) }; });
      var errorsData = requestsTsData.map(function(r) { return { x: r['bucket'], y: r['error_requests'] || 0 }; });
      
      var p50Data = latencyTsData.map(function(r) { return { x: r['bucket'], y: r['p50'] || 0 }; });
      var p90Data = latencyTsData.map(function(r) { return { x: r['bucket'], y: r['p90'] || 0 }; });
      var p99Data = latencyTsData.map(function(r) { return { x: r['bucket'], y: r['p99'] || 0 }; });

      var chartOptions = {
        chart: { type: 'area', height: 250, toolbar: { show: false }, animations: { enabled: false } },
        dataLabels: { enabled: false },
        xaxis: { type: 'datetime', labels: { datetimeUTC: false } },
        stroke: { curve: 'smooth', width: 2 },
        fill: { type: 'solid', opacity: 0.1 },
        tooltip: { x: { format: 'HH:mm' } }
      };

      var requestsOptions = Object.assign({}, chartOptions, {
        chart: { type: 'line', height: 250, toolbar: { show: false }, animations: { enabled: false } },
        series: [
          { name: 'Successful Requests', type: 'area', data: requestsData },
          { name: 'Errors', type: 'line', data: errorsData }
        ],
        colors: ['#3B82F6', '#EF4444'],
        stroke: { curve: 'smooth', width: [2, 3] },
        fill: { type: ['solid', 'solid'], opacity: [0.1, 1] },
        yaxis: { labels: { formatter: function(v) { return Math.round(v); } } }
      });
      new ApexCharts(reqEl, requestsOptions).render();

      var latencyOptions = Object.assign({}, chartOptions, {
        series: [
          { name: 'P50', data: p50Data },
          { name: 'P90', data: p90Data },
          { name: 'P99', data: p99Data }
        ],
        colors: ['#10B981', '#F59E0B', '#EF4444'],
        yaxis: { labels: { formatter: function(v) { return v.toFixed(1) + 'ms'; } } }
      });
      new ApexCharts(latEl, latencyOptions).render();
    }

    renderCharts();
  })();
  </script>
<% else %>
  <div class="stat-card">
    <p class="text-gray-500 text-center py-8">This tab is under construction.</p>
  </div>
<% end %>
